---
const year = new Date().getFullYear();

const links = [
  { title: "Home", href: "/" },
  { title: "About", href: "/about" },
  { title: "Projects", href: "/projects" },
  { title: "Blog", href: "/blog" },
];

const socials = [
  {
    title: "GitHub",
    href: "https://github.com/PraveenK1618",
  },
  {
    title: "LinkedIn",
    href: "https://www.linkedin.com/in/praveen--kumar-/",
  },
  {
    title: "Resume",
    href: "/PRAVEEN_KUMAR_ECE_RESUME.pdf",
  },
  {
    title: "RSS",
    href: "/rss.xml",
  },
];
---

<footer class="footer">
  <div class="container footer-grid">
    <div class="brand">
      <h2>Praveen Builds.</h2>

      <p>
        Building practical products across embedded systems,
        software engineering, automation and computer vision.
      </p>
    </div>

    <div>
      <h3>Navigate</h3>

      <ul>
        {
          links.map((link) => (
            <li>
              <a href={link.href}>{link.title}</a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <h3>Connect</h3>

      <ul>
        {
          socials.map((item) => (
            <li>
              <a
                href={item.href}
                target="_blank"
                rel="noopener noreferrer"
              >
                {item.title}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <div class="footer-bottom container">
    <p>
      © {year} Praveen Kumar. Built with Astro & Vercel.
    </p>

    <a href="#">Back to top ↑</a>
  </div>
</footer>

<style>
.footer{
margin-top:0;
padding:70px 0 30px;
border-top:1px solid var(--border);
background:#050816;
}

.footer-grid{
display:grid;
grid-template-columns:2fr 1fr 1fr;
gap:60px;
}

.brand h2{
font-size:2rem;
margin-bottom:15px;
}

.brand p{
max-width:420px;
line-height:1.8;
color:var(--text-secondary);
}

.footer h3{
margin-bottom:18px;
font-size:.95rem;
color:var(--accent);
}

.footer ul{
list-style:none;
padding:0;
margin:0;
}

.footer li{
margin-bottom:12px;
}

.footer a{
color:var(--text-secondary);
transition:.2s;
}

.footer a:hover{
color:var(--accent);
}

.footer-bottom{
margin-top:60px;
padding-top:25px;
border-top:1px solid #18283d;
display:flex;
justify-content:space-between;
align-items:center;
font-size:.9rem;
color:var(--text-muted);
}

@media(max-width:800px){

.footer-grid{
grid-template-columns:1fr;
gap:40px;
}

.footer-bottom{
flex-direction:column;
gap:15px;
text-align:center;
}

}
</style>