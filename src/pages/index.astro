---
import BaseLayout from "../layouts/BaseLayout.astro";

const projects = [
  {
    title: "FuelSave India",
    description:
      "A Flutter application for tracking fuel expenses, mileage, vehicle performance and savings.",
    tag: "Flutter • SQLite",
  },
  {
    title: "Vision-Based Component Sorting",
    description:
      "An OpenCV and STM32-based system developed during my internship at SCL Mohali.",
    tag: "OpenCV • STM32",
  },
  {
    title: "PLC Pick and Place Machine",
    description:
      "An industrial automation project using PLC control, motors and pneumatic components.",
    tag: "PLC • Automation",
  },
];

const skills = [
  "Flutter",
  "Dart",
  "STM32",
  "OpenCV",
  "Python",
  "Electronics",
  "IoT",
  "PLC Automation",
];
---

<BaseLayout
  title="Praveen Builds | Electronics Engineer and Product Builder"
  description="Praveen Kumar builds software, electronics and automation projects while sharing practical engineering knowledge."
>
  <section class="hero container">
    <div class="hero-content">
      <p class="eyebrow">Electronics Engineer • Developer • Builder</p>

      <h1>
        I build practical products and
        <span>share the journey.</span>
      </h1>

      <p class="hero-description">
        I'm Praveen Kumar, an Electronics and Communication Engineering
        student building applications, embedded systems and automation
        projects—including FuelSave India.
      </p>

      <div class="buttons">
        <a class="primary-button" href="#projects">Explore my projects</a>

        <a
          class="secondary-button"
          href="https://github.com/PraveenK1618"
          target="_blank"
          rel="noopener noreferrer"
        >
          View GitHub
        </a>
      </div>
    </div>

    <aside class="builder-card">
      <p class="card-label">Currently building</p>

      <h2>FuelSave India</h2>

      <p>
        Helping vehicle owners understand fuel costs, mileage and savings.
      </p>

      <div class="status">
        <span class="status-dot"></span>
        Active project
      </div>
    </aside>
  </section>

  <section class="section container" id="about">
    <p class="section-label">About me</p>

    <h2 class="section-title">
      Engineering ideas into useful products.
    </h2>

    <p class="section-description">
      My work combines electronics, software development, computer vision and
      industrial automation. This website documents what I build, lessons I
      learn and resources that may help other engineering students.
    </p>

    <div class="skills">
      {
        skills.map((skill) => (
          <span>{skill}</span>
        ))
      }
    </div>
  </section>

  <section class="section container" id="projects">
    <p class="section-label">Selected work</p>

    <h2 class="section-title">
      Projects built through learning and experimentation.
    </h2>

    <div class="project-grid">
      {
        projects.map((project) => (
          <article class="project-card">
            <p class="project-tag">{project.tag}</p>

            <h3>{project.title}</h3>

            <p>{project.description}</p>

            <span class="coming-soon">Case study coming soon →</span>
          </article>
        ))
      }
    </div>
  </section>

  <section class="contact-section container" id="contact">
    <div>
      <p class="section-label">Let's connect</p>

      <h2>
        Interested in engineering, technology or product building?
      </h2>
    </div>

    <a
      class="primary-button"
      href="https://www.linkedin.com/in/praveen--kumar-/"
      target="_blank"
      rel="noopener noreferrer"
    >
      Connect on LinkedIn
    </a>
  </section>
</BaseLayout>

<style>
  .hero {
    min-height: 650px;
    padding-block: 100px;
    display: grid;
    grid-template-columns: 1.45fr 0.75fr;
    align-items: center;
    gap: 80px;
  }

  .eyebrow,
  .card-label,
  .project-tag {
    margin: 0;
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1 {
    max-width: 780px;
    margin: 18px 0 24px;
    font-size: clamp(3rem, 7vw, 5.8rem);
    line-height: 0.98;
    letter-spacing: -0.065em;
  }

  h1 span {
    color: var(--accent);
  }

  .hero-description {
    max-width: 680px;
    color: var(--text-secondary);
    font-size: 1.1rem;
    line-height: 1.8;
  }

  .buttons {
    margin-top: 36px;
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
  }

  .builder-card,
  .project-card {
    border: 1px solid var(--border);
    background: rgba(12, 26, 44, 0.75);
    backdrop-filter: blur(12px);
  }

  .builder-card {
    padding: 34px;
    border-radius: var(--radius-large);
    box-shadow: 0 28px 80px rgba(0, 0, 0, 0.25);
  }

  .builder-card h2 {
    margin: 10px 0;
    font-size: 2rem;
  }

  .builder-card > p:not(.card-label) {
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .status {
    margin-top: 28px;
    display: flex;
    align-items: center;
    gap: 9px;
    color: #b9c7d9;
    font-size: 0.9rem;
  }

  .status-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--success);
    box-shadow: 0 0 18px var(--success);
  }

  .skills {
    margin-top: 32px;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .skills span {
    padding: 9px 14px;
    border: 1px solid #26374e;
    border-radius: 999px;
    color: #c4cfdd;
    background: var(--surface);
  }

  .project-grid {
    margin-top: 48px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
  }

  .project-card {
    padding: 28px;
    border-radius: var(--radius-medium);
    transition:
      transform 180ms ease,
      border-color 180ms ease;
  }

  .project-card:hover {
    border-color: var(--accent);
    transform: translateY(-5px);
  }

  .project-card h3 {
    margin: 12px 0;
    font-size: 1.35rem;
  }

  .project-card > p:not(.project-tag) {
    min-height: 105px;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .coming-soon {
    color: var(--accent);
    font-size: 0.92rem;
    font-weight: 700;
  }

  .contact-section {
    margin-block: 60px 100px;
    padding: 60px;
    border: 1px solid var(--border);
    border-radius: var(--radius-large);
    background: var(--surface);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
  }

  .contact-section h2 {
    max-width: 760px;
    margin: 12px 0 0;
    font-size: clamp(2rem, 5vw, 3.4rem);
    line-height: 1.1;
    letter-spacing: -0.045em;
  }

  @media (max-width: 850px) {
    .hero {
      min-height: auto;
      padding-block: 80px;
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .project-grid {
      grid-template-columns: 1fr;
    }

    .project-card > p:not(.project-tag) {
      min-height: auto;
    }

    .contact-section {
      padding: 36px 24px;
      align-items: flex-start;
      flex-direction: column;
    }
  }

  @media (max-width: 520px) {
    h1 {
      font-size: 3.2rem;
    }

    .buttons {
      flex-direction: column;
    }
  }
</style>