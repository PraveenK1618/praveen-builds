---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const allPosts = await getCollection("blog", ({ data }) => data.draft !== true);

const latestPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const projects = [
  {
    number: "01",
    title: "FuelSave India",
    description:
      "A Flutter application that helps vehicle owners track fuel expenses, mileage, running cost and savings.",
    technologies: ["Flutter", "Dart", "SQLite", "Analytics"],
    status: "Active development",
    href: "#building-now",
    featured: true,
  },
  {
    number: "02",
    title: "Vision-Based Component Sorting",
    description:
      "A computer-vision and motion-control system developed during my project internship at Semiconductor Laboratory, Mohali.",
    technologies: ["OpenCV", "STM32", "Python", "Automation"],
    status: "Completed",
    href: "#journey",
    featured: false,
  },
  {
    number: "03",
    title: "PLC Pick and Place Machine",
    description:
      "An industrial automation project involving PLC control, motors, sensors and pneumatic components.",
    technologies: ["PLC", "Automation", "Motors", "Pneumatics"],
    status: "Completed",
    href: "#journey",
    featured: false,
  },
];

const timeline = [
  {
    period: "Apr 2024 – Oct 2024",
    role: "Graphic Designer",
    organisation: "E-Cell UIET KUK",
    description:
      "Created visual communication and promotional designs for entrepreneurship activities and campus events.",
    type: "Design",
  },
  {
    period: "Jul 2024 – Aug 2024",
    role: "Electronic Engineering Intern",
    organisation: "ENS Engineering Technology",
    description:
      "Worked with PLC panels, motors, drivers, relays, industrial wiring and a pick-and-place automation system.",
    type: "Engineering",
  },
  {
    period: "Oct 2024 – Oct 2025",
    role: "Design Lead",
    organisation: "E-Cell UIET KUK",
    description:
      "Promoted to lead the design team, supervise visual communication and coordinate creative deliverables.",
    type: "Leadership",
  },
  {
    period: "Jul 2025 – Aug 2025",
    role: "Onsite Engineer Intern",
    organisation: "Echelon Edge Pvt. Ltd.",
    description:
      "Gained practical onsite engineering exposure while working in a professional technology environment.",
    type: "Engineering",
  },
  {
    period: "Jan 2026 – May 2026",
    role: "Project Intern",
    organisation: "Semiconductor Laboratory, Mohali",
    description:
      "Developed a vision-based component orientation and automated sorting system using OpenCV, STM32 and motion control.",
    type: "Research & Development",
  },
  {
    period: "Jun 2026 – Present",
    role: "Founder & Developer",
    organisation: "FuelSave India",
    description:
      "Building a practical vehicle fuel, mileage and expense-tracking product using Flutter and local-first data storage.",
    type: "Product Building",
  },
];

const stats = [
  { value: "3+", label: "Engineering projects" },
  { value: "4 mo", label: "SCL project internship" },
  { value: "2", label: "Engineering internships" },
  { value: "1", label: "Active product" },
];

function formatDate(date: Date) {
  return new Intl.DateTimeFormat("en-IN", {
    day: "numeric",
    month: "short",
    year: "numeric",
  }).format(date);
}
---

<BaseLayout
  title="Praveen Builds | Engineer, Developer and Product Builder"
  description="Praveen Kumar builds practical products across software, electronics, computer vision and industrial automation."
>
  <div class="page-background" aria-hidden="true">
    <div class="grid"></div>
    <div class="glow glow-one"></div>
    <div class="glow glow-two"></div>
  </div>

  <section class="hero container">
    <div class="hero-content">
      <div class="availability">
        <span class="availability-dot"></span>
        Building FuelSave India
      </div>

      <p class="hero-label">Electronics Engineer · Developer · Product Builder</p>

      <h1>
        Building products that solve
        <span>real-world problems.</span>
      </h1>

      <p class="hero-description">
        I'm Praveen Kumar. I combine electronics, software development,
        computer vision and automation to turn practical ideas into working
        products.
      </p>

      <div class="hero-actions">
        <a class="primary-button" href: "/projects",>
          Explore my work
          <span aria-hidden="true">↗</span>
        </a>

        <a class="secondary-button" href="/blog">
          Read the blog
        </a>
      </div>

      <div class="hero-links">
        <a
          href="https://github.com/PraveenK1618"
          target="_blank"
          rel="noopener noreferrer"
        >
          GitHub ↗
        </a>

        <a href="#contact">LinkedIn ↗</a>
      </div>
    </div>

    <div class="hero-visual">
      <div class="terminal-card">
        <div class="terminal-top">
          <div class="terminal-dots">
            <span></span>
            <span></span>
            <span></span>
          </div>

          <span>praveen-builds</span>
        </div>

        <div class="terminal-body">
          <p><span class="prompt">›</span> currently_building</p>
          <h2>FuelSave India</h2>

          <div class="terminal-line">
            <span>platform</span>
            <strong>Flutter</strong>
          </div>

          <div class="terminal-line">
            <span>database</span>
            <strong>SQLite</strong>
          </div>

          <div class="terminal-line">
            <span>status</span>
            <strong class="active-text">Active</strong>
          </div>

          <div class="terminal-line">
            <span>mission</span>
            <strong>Smarter vehicle ownership</strong>
          </div>

          <div class="progress">
            <div class="progress-heading">
              <span>Product progress</span>
              <span>78%</span>
            </div>

            <div class="progress-track">
              <span></span>
            </div>
          </div>
        </div>
      </div>

      <div class="floating-chip chip-one">STM32</div>
      <div class="floating-chip chip-two">Flutter</div>
      <div class="floating-chip chip-three">OpenCV</div>
    </div>
  </section>

  <section class="stats container" aria-label="Career statistics">
    {
      stats.map((stat) => (
        <div class="stat">
          <strong>{stat.value}</strong>
          <span>{stat.label}</span>
        </div>
      ))
    }
  </section>

  <section class="section container" id="projects">
    <div class="section-heading">
      <div>
        <p class="section-label">Selected projects</p>

        <h2 class="section-title">
          Practical engineering, not just theoretical exercises.
        </h2>
      </div>

      <p class="section-intro">
        Every project represents a problem I explored, a system I designed and
        lessons I gained through implementation.
      </p>
    </div>

    <div class="projects-grid">
      {
        projects.map((project) => (
          <article
            class:list={[
              "project-card",
              { featured: project.featured },
            ]}
          >
            <div class="project-top">
              <span class="project-number">{project.number}</span>

              <span
                class:list={[
                  "project-status",
                  { active: project.status === "Active development" },
                ]}
              >
                {project.status}
              </span>
            </div>

            <div class="project-body">
              <h3>{project.title}</h3>
              <p>{project.description}</p>

              <div class="technology-list">
                {project.technologies.map((technology) => (
                  <span>{technology}</span>
                ))}
              </div>
            </div>

            <a class="project-link" href={project.href}>
              Explore project
              <span aria-hidden="true">↗</span>
            </a>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section journey-section" id="journey">
    <div class="container">
      <div class="section-heading">
        <div>
          <p class="section-label">Engineering journey</p>

          <h2 class="section-title">
            From design and automation to building complete products.
          </h2>
        </div>

        <p class="section-intro">
          My journey combines technical engineering, creative communication,
          team leadership and product development.
        </p>
      </div>

      <div class="timeline">
        {
          timeline.map((item, index) => (
            <article class="timeline-item">
              <div class="timeline-marker">
                <span>{String(index + 1).padStart(2, "0")}</span>
              </div>

              <div class="timeline-period">{item.period}</div>

              <div class="timeline-content">
                <span class="timeline-type">{item.type}</span>
                <h3>{item.role}</h3>
                <h4>{item.organisation}</h4>
                <p>{item.description}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section container building-section" id="building-now">
    <div class="building-card">
      <div class="building-copy">
        <div class="building-heading">
          <span class="live-indicator">
            <span></span>
            Building now
          </span>

          <span class="updated">Active project</span>
        </div>

        <p class="section-label">FuelSave India</p>

        <h2>
          Helping people understand the true cost of running their vehicles.
        </h2>

        <p>
          FuelSave India records fuel entries and converts them into meaningful
          insights such as mileage, cost per kilometre, monthly spending and
          vehicle-wise performance.
        </p>

        <div class="building-actions">
          <a class="primary-button" href="/blog/why-i-built-fuelsave-india">
            Read the story
          </a>

          <a class="secondary-button" href="#contact">
            Follow the journey
          </a>
        </div>
      </div>

      <div class="sprint-card">
        <div class="sprint-header">
          <span>Current product roadmap</span>
          <span>78%</span>
        </div>

        <div class="roadmap-progress">
          <span></span>
        </div>

        <ul>
          <li class="complete">
            <span>✓</span>
            Fuel and mileage tracking
          </li>
          <li class="complete">
            <span>✓</span>
            Multi-vehicle analytics
          </li>
          <li class="complete">
            <span>✓</span>
            Backup and restore
          </li>
          <li>
            <span>○</span>
            OBD-II automation
          </li>
          <li>
            <span>○</span>
            Smarter fuel-price assistance
          </li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section container articles-section">
    <div class="section-heading">
      <div>
        <p class="section-label">Latest writing</p>

        <h2 class="section-title">
          Lessons, decisions and experiments from the work.
        </h2>
      </div>

      <a class="text-link" href="/blog">View all articles ↗</a>
    </div>

    <div class="articles-grid">
      {
        latestPosts.map((post, index) => (
          <article class:list={["article-card", { featured: index === 0 }]}>
            <div class="article-meta">
              <span>{post.data.category}</span>
              <span>{formatDate(post.data.pubDate)}</span>
            </div>

            <h3>
              <a href={`/blog/${post.id}`}>{post.data.title}</a>
            </h3>

            <p>{post.data.description}</p>

            <div class="article-footer">
              <span>{post.data.readingTime}</span>
              <a href={`/blog/${post.id}`}>Read article ↗</a>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="contact container" id="contact">
    <div>
      <p class="section-label">Let's connect</p>

      <h2>
        Have an engineering idea, opportunity or interesting problem?
      </h2>

      <p>
        I'm open to engineering roles, collaborations and conversations about
        electronics, embedded systems, Flutter and practical product building.
      </p>
    </div>

    <div class="contact-actions">
      <a
        class="primary-button"
        href="https://www.linkedin.com/in/praveen--kumar-/"
        target="_blank"
        rel="noopener noreferrer"
      >
        Connect on LinkedIn
      </a>

      <a
        class="secondary-button"
        href="https://github.com/PraveenK1618"
        target="_blank"
        rel="noopener noreferrer"
      >
        Visit GitHub
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .page-background {
    position: fixed;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    pointer-events: none;
  }

  .grid {
    position: absolute;
    inset: 0;
    opacity: 0.18;
    background-image:
      linear-gradient(rgba(85, 165, 255, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(85, 165, 255, 0.08) 1px, transparent 1px);
    background-size: 72px 72px;
    mask-image: linear-gradient(to bottom, black, transparent 75%);
  }

  .glow {
    position: absolute;
    border-radius: 999px;
    filter: blur(100px);
    opacity: 0.2;
  }

  .glow-one {
    width: 520px;
    height: 520px;
    top: -180px;
    right: -120px;
    background: #2563eb;
  }

  .glow-two {
    width: 420px;
    height: 420px;
    top: 520px;
    left: -250px;
    background: #0891b2;
  }

  .hero {
    min-height: 760px;
    padding-block: 110px 90px;
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(350px, 0.8fr);
    align-items: center;
    gap: 90px;
  }

  .availability {
    width: fit-content;
    padding: 8px 13px;
    border: 1px solid rgba(16, 185, 129, 0.25);
    border-radius: 999px;
    color: #9de7c7;
    background: rgba(16, 185, 129, 0.08);
    display: flex;
    align-items: center;
    gap: 9px;
    font-size: 0.82rem;
    font-weight: 700;
  }

  .availability-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #10b981;
    box-shadow: 0 0 15px rgba(16, 185, 129, 0.9);
  }

  .hero-label {
    margin: 28px 0 0;
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1 {
    max-width: 850px;
    margin: 18px 0 28px;
    font-size: clamp(3.4rem, 7vw, 6.7rem);
    line-height: 0.94;
    letter-spacing: -0.075em;
  }

  h1 span {
    display: block;
    color: transparent;
    background: linear-gradient(100deg, #55a5ff, #5eead4);
    background-clip: text;
    -webkit-background-clip: text;
  }

  .hero-description {
    max-width: 680px;
    color: var(--text-secondary);
    font-size: 1.12rem;
    line-height: 1.85;
  }

  .hero-actions,
  .building-actions,
  .contact-actions {
    margin-top: 36px;
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
  }

  .hero-links {
    margin-top: 30px;
    display: flex;
    gap: 24px;
  }

  .hero-links a,
  .text-link {
    color: var(--text-muted);
    font-size: 0.9rem;
    font-weight: 700;
    transition: color 180ms ease;
  }

  .hero-links a:hover,
  .text-link:hover {
    color: var(--accent);
  }

  .hero-visual {
    position: relative;
  }

  .terminal-card {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(85, 165, 255, 0.22);
    border-radius: 24px;
    background:
      linear-gradient(145deg, rgba(17, 24, 39, 0.96), rgba(5, 8, 22, 0.98));
    box-shadow:
      0 35px 100px rgba(0, 0, 0, 0.42),
      inset 0 1px rgba(255, 255, 255, 0.05);
    transform: perspective(1000px) rotateY(-4deg) rotateX(2deg);
  }

  .terminal-card::before {
    position: absolute;
    width: 190px;
    height: 190px;
    top: -70px;
    right: -50px;
    border-radius: 50%;
    background: rgba(39, 136, 255, 0.2);
    filter: blur(50px);
    content: "";
  }

  .terminal-top {
    padding: 15px 18px;
    border-bottom: 1px solid rgba(148, 163, 184, 0.12);
    color: var(--text-muted);
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: monospace;
    font-size: 0.75rem;
  }

  .terminal-dots {
    display: flex;
    gap: 7px;
  }

  .terminal-dots span {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: #334155;
  }

  .terminal-body {
    padding: 36px;
  }

  .terminal-body > p {
    margin: 0;
    color: var(--text-muted);
    font-family: monospace;
    font-size: 0.86rem;
  }

  .prompt {
    color: #5eead4;
  }

  .terminal-body h2 {
    margin: 12px 0 30px;
    font-size: 2.2rem;
    letter-spacing: -0.045em;
  }

  .terminal-line {
    padding: 13px 0;
    border-bottom: 1px solid rgba(148, 163, 184, 0.1);
    display: flex;
    justify-content: space-between;
    gap: 20px;
    font-family: monospace;
    font-size: 0.83rem;
  }

  .terminal-line span {
    color: var(--text-muted);
  }

  .terminal-line strong {
    color: #d9e4f2;
    text-align: right;
  }

  .terminal-line .active-text {
    color: #6ee7b7;
  }

  .progress {
    margin-top: 30px;
  }

  .progress-heading {
    margin-bottom: 10px;
    color: var(--text-muted);
    display: flex;
    justify-content: space-between;
    font-size: 0.78rem;
  }

  .progress-track,
  .roadmap-progress {
    height: 7px;
    overflow: hidden;
    border-radius: 999px;
    background: #172033;
  }

  .progress-track span,
  .roadmap-progress span {
    display: block;
    width: 78%;
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, #3b82f6, #06b6d4);
  }

  .floating-chip {
    position: absolute;
    padding: 9px 13px;
    border: 1px solid rgba(85, 165, 255, 0.25);
    border-radius: 10px;
    color: #b8d7ff;
    background: rgba(8, 17, 31, 0.88);
    backdrop-filter: blur(12px);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.28);
    font-family: monospace;
    font-size: 0.76rem;
    font-weight: 700;
  }

  .chip-one {
    top: -25px;
    right: 30px;
  }

  .chip-two {
    bottom: 55px;
    left: -45px;
  }

  .chip-three {
    right: -38px;
    bottom: -20px;
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid #142238;
    border-bottom: 1px solid #142238;
  }

  .stat {
    min-height: 145px;
    padding: 30px;
    border-right: 1px solid #142238;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .stat:last-child {
    border-right: 0;
  }

  .stat strong {
    font-size: 2.2rem;
    letter-spacing: -0.04em;
  }

  .stat span {
    margin-top: 8px;
    color: var(--text-muted);
    font-size: 0.88rem;
  }

  .section-heading {
    display: grid;
    grid-template-columns: 1fr minmax(260px, 420px);
    align-items: end;
    gap: 60px;
  }

  .section-intro {
    margin: 0 0 22px;
    color: var(--text-secondary);
    line-height: 1.8;
  }

  .projects-grid {
    margin-top: 60px;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 22px;
  }

  .project-card {
    min-height: 390px;
    padding: 30px;
    border: 1px solid var(--border);
    border-radius: 22px;
    background: rgba(11, 18, 32, 0.72);
    display: flex;
    flex-direction: column;
    transition:
      transform 220ms ease,
      border-color 220ms ease,
      background 220ms ease;
  }

  .project-card.featured {
    grid-column: span 2;
    min-height: 440px;
    background:
      radial-gradient(
        circle at 90% 10%,
        rgba(39, 136, 255, 0.18),
        transparent 38%
      ),
      rgba(11, 18, 32, 0.82);
  }

  .project-card:hover {
    border-color: rgba(85, 165, 255, 0.55);
    background-color: rgba(16, 33, 57, 0.8);
    transform: translateY(-6px);
  }

  .project-top {
    display: flex;
    justify-content: space-between;
    gap: 20px;
  }

  .project-number {
    color: #41506a;
    font-family: monospace;
    font-size: 0.85rem;
  }

  .project-status {
    padding: 6px 10px;
    border: 1px solid #273449;
    border-radius: 999px;
    color: var(--text-muted);
    font-size: 0.72rem;
    font-weight: 700;
  }

  .project-status.active {
    border-color: rgba(16, 185, 129, 0.25);
    color: #8ce4bd;
    background: rgba(16, 185, 129, 0.07);
  }

  .project-body {
    margin-block: auto;
  }

  .project-body h3 {
    max-width: 620px;
    margin: 35px 0 14px;
    font-size: clamp(1.7rem, 3vw, 2.6rem);
    letter-spacing: -0.045em;
  }

  .project-body p {
    max-width: 680px;
    color: var(--text-secondary);
    line-height: 1.75;
  }

  .technology-list {
    margin-top: 24px;
    display: flex;
    flex-wrap: wrap;
    gap: 9px;
  }

  .technology-list span {
    padding: 7px 10px;
    border: 1px solid #243248;
    border-radius: 8px;
    color: #9fb1c8;
    background: rgba(5, 8, 22, 0.45);
    font-size: 0.75rem;
  }

  .project-link {
    margin-top: 32px;
    color: var(--accent);
    display: flex;
    justify-content: space-between;
    font-weight: 700;
  }

  .journey-section {
    border-top: 1px solid #142238;
    background: rgba(5, 8, 22, 0.5);
  }

  .timeline {
    position: relative;
    margin-top: 70px;
  }

  .timeline::before {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 27px;
    width: 1px;
    background: linear-gradient(var(--accent), rgba(85, 165, 255, 0.05));
    content: "";
  }

  .timeline-item {
    position: relative;
    min-height: 190px;
    padding: 0 0 60px 85px;
    display: grid;
    grid-template-columns: 190px 1fr;
    gap: 45px;
  }

  .timeline-marker {
    position: absolute;
    top: 0;
    left: 0;
    width: 55px;
    height: 55px;
    border: 1px solid rgba(85, 165, 255, 0.35);
    border-radius: 50%;
    color: var(--accent);
    background: #07111f;
    display: grid;
    place-items: center;
    font-family: monospace;
    font-size: 0.72rem;
    box-shadow: 0 0 0 8px #07111f;
  }

  .timeline-period {
    padding-top: 5px;
    color: var(--text-muted);
    font-size: 0.84rem;
    font-weight: 700;
  }

  .timeline-type {
    color: var(--accent);
    font-size: 0.7rem;
