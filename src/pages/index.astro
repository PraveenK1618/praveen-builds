---
const projects = [
  {
    title: "FuelSave India",
    description:
      "A Flutter application for tracking fuel expenses, mileage, vehicle performance and savings.",
    tag: "Flutter • SQLite",
  },
  {
    title: "Vision-Based Component Sorting",
    description:
      "An OpenCV and STM32-based system developed during my internship at SCL Mohali.",
    tag: "OpenCV • STM32",
  },
  {
    title: "PLC Pick and Place Machine",
    description:
      "An industrial automation project using PLC control, motors and pneumatic components.",
    tag: "PLC • Automation",
  },
];

const skills = [
  "Flutter",
  "Dart",
  "STM32",
  "OpenCV",
  "Python",
  "Electronics",
  "IoT",
  "PLC Automation",
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />

    <title>Praveen Builds | Electronics Engineer and Product Builder</title>

    <meta
      name="description"
      content="Praveen Kumar builds software, electronics and automation projects while sharing practical engineering knowledge."
    />
  </head>

  <body>
    <header class="navbar">
      <a class="logo" href="/">Praveen<span>Builds</span></a>

      <nav aria-label="Main navigation">
        <a href="#about">About</a>
        <a href="#projects">Projects</a>
        <a href="/blog">Blog</a>
        <a href="#contact">Contact</a>
      </nav>
    </header>

    <main>
      <section class="hero">
        <div class="hero-content">
          <p class="eyebrow">Electronics Engineer • Developer • Builder</p>

          <h1>
            I build practical products and
            <span>share the journey.</span>
          </h1>

          <p class="hero-description">
            I'm Praveen Kumar, an Electronics and Communication Engineering
            student building applications, embedded systems and automation
            projects—including FuelSave India.
          </p>

          <div class="buttons">
            <a class="primary-button" href="#projects">Explore my projects</a>

            <a
              class="secondary-button"
              href="https://github.com/PraveenK1618"
              target="_blank"
              rel="noopener noreferrer"
            >
              View GitHub
            </a>
          </div>
        </div>

        <aside class="builder-card">
          <p class="card-label">Currently building</p>
          <h2>FuelSave India</h2>

          <p>
            Helping vehicle owners understand fuel costs, mileage and savings.
          </p>

          <div class="status">
            <span class="status-dot"></span>
            Active project
          </div>
        </aside>
      </section>

      <section class="section" id="about">
        <p class="section-label">About me</p>
        <h2>Engineering ideas into useful products.</h2>

        <p class="section-description">
          My work combines electronics, software development, computer vision
          and industrial automation. This website documents what I build,
          lessons I learn and resources that may help other engineering
          students.
        </p>

        <div class="skills">
          {
            skills.map((skill) => (
              <span>{skill}</span>
            ))
          }
        </div>
      </section>

      <section class="section" id="projects">
        <p class="section-label">Selected work</p>
        <h2>Projects built through learning and experimentation.</h2>

        <div class="project-grid">
          {
            projects.map((project) => (
              <article class="project-card">
                <p class="project-tag">{project.tag}</p>
                <h3>{project.title}</h3>
                <p>{project.description}</p>
                <a href="#">Case study coming soon →</a>
              </article>
            ))
          }
        </div>
      </section>

      <section class="contact-section" id="contact">
        <div>
          <p class="section-label">Let's connect</p>
          <h2>Interested in engineering, technology or product building?</h2>
        </div>

        <a
          class="primary-button"
          href="https://www.linkedin.com/in/praveen--kumar-/"
          target="_blank"
          rel="noopener noreferrer"
        >
          Connect on LinkedIn
        </a>
      </section>
    </main>

    <footer>
      <p>© {new Date().getFullYear()} Praveen Kumar</p>
      <p>Building products. Sharing the journey.</p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
    color: #e8edf6;
    background: #07111f;
    font-synthesis: none;
    line-height: 1.5;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-width: 320px;
    background:
      radial-gradient(circle at 80% 10%, rgba(27, 121, 255, 0.14), transparent 30%),
      #07111f;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .navbar {
    width: min(1180px, calc(100% - 40px));
    min-height: 76px;
    margin: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    font-size: 1.15rem;
    font-weight: 800;
    letter-spacing: -0.03em;
  }

  .logo span {
    color: #55a5ff;
  }

  nav {
    display: flex;
    gap: 28px;
  }

  nav a {
    color: #a9b5c8;
    font-size: 0.94rem;
  }

  nav a:hover {
    color: white;
  }

  main {
    width: min(1180px, calc(100% - 40px));
    margin: auto;
  }

  .hero {
    min-height: 650px;
    padding: 100px 0;
    display: grid;
    grid-template-columns: 1.45fr 0.75fr;
    align-items: center;
    gap: 80px;
  }

  .eyebrow,
  .section-label,
  .card-label,
  .project-tag {
    color: #55a5ff;
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1 {
    max-width: 780px;
    margin: 18px 0 24px;
    font-size: clamp(3rem, 7vw, 5.8rem);
    line-height: 0.98;
    letter-spacing: -0.065em;
  }

  h1 span {
    color: #55a5ff;
  }

  .hero-description {
    max-width: 680px;
    color: #a9b5c8;
    font-size: 1.1rem;
    line-height: 1.8;
  }

  .buttons {
    margin-top: 36px;
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
  }

  .primary-button,
  .secondary-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 50px;
    padding: 0 22px;
    border-radius: 10px;
    font-weight: 700;
  }

  .primary-button {
    background: #2788ff;
    color: white;
  }

  .primary-button:hover {
    background: #0d75f4;
  }

  .secondary-button {
    border: 1px solid #29384c;
    color: #dbe6f5;
  }

  .secondary-button:hover {
    border-color: #55a5ff;
  }

  .builder-card,
  .project-card {
    border: 1px solid #1d2d42;
    background: rgba(12, 26, 44, 0.75);
    backdrop-filter: blur(12px);
  }

  .builder-card {
    padding: 34px;
    border-radius: 24px;
    box-shadow: 0 28px 80px rgba(0, 0, 0, 0.25);
  }

  .builder-card h2 {
    margin: 10px 0;
    font-size: 2rem;
  }

  .builder-card > p:not(.card-label) {
    color: #9eacc0;
    line-height: 1.7;
  }

  .status {
    margin-top: 28px;
    display: flex;
    align-items: center;
    gap: 9px;
    color: #b9c7d9;
    font-size: 0.9rem;
  }

  .status-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: #42d392;
    box-shadow: 0 0 18px #42d392;
  }

  .section {
    padding: 110px 0;
    border-top: 1px solid #142238;
  }

  .section h2,
  .contact-section h2 {
    max-width: 760px;
    margin: 12px 0 22px;
    font-size: clamp(2rem, 5vw, 3.4rem);
    line-height: 1.1;
    letter-spacing: -0.045em;
  }

  .section-description {
    max-width: 760px;
    color: #a9b5c8;
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .skills {
    margin-top: 32px;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .skills span {
    padding: 9px 14px;
    border: 1px solid #26374e;
    border-radius: 999px;
    color: #c4cfdd;
    background: #0b192b;
  }

  .project-grid {
    margin-top: 48px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
  }

  .project-card {
    padding: 28px;
    border-radius: 18px;
  }

  .project-card h3 {
    margin: 12px 0;
    font-size: 1.35rem;
  }

  .project-card > p:not(.project-tag) {
    min-height: 105px;
    color: #9eacc0;
    line-height: 1.7;
  }

  .project-card a {
    color: #55a5ff;
    font-weight: 700;
    font-size: 0.92rem;
  }

  .contact-section {
    margin: 60px 0 100px;
    padding: 60px;
    border: 1px solid #1d2d42;
    border-radius: 24px;
    background: #0b192b;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
  }

  footer {
    width: min(1180px, calc(100% - 40px));
    margin: auto;
    padding: 30px 0;
    border-top: 1px solid #142238;
    color: #75849a;
    display: flex;
    justify-content: space-between;
    gap: 20px;
    font-size: 0.9rem;
  }

  @media (max-width: 850px) {
    nav {
      display: none;
    }

    .hero {
      min-height: auto;
      padding: 80px 0;
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .project-grid {
      grid-template-columns: 1fr;
    }

    .contact-section {
      padding: 36px 24px;
      align-items: flex-start;
      flex-direction: column;
    }
  }

  @media (max-width: 520px) {
    .navbar,
    main,
    footer {
      width: min(100% - 28px, 1180px);
    }

    h1 {
      font-size: 3.2rem;
    }

    .buttons {
      flex-direction: column;
    }

    .primary-button,
    .secondary-button {
      width: 100%;
    }

    footer {
      flex-direction: column;
    }
  }
</style>