---
const posts = [
  {
    title: "Why I Built FuelSave India",
    description:
      "The problem that inspired me to build a fuel, mileage and vehicle expense tracking application.",
    date: "14 July 2026",
    category: "FuelSave India",
    readingTime: "5 min read",
    href: "/blog/why-i-built-fuelsave-india",
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />

    <title>Blog | Praveen Builds</title>

    <meta
      name="description"
      content="Articles by Praveen Kumar about Flutter, electronics, embedded systems, automation and building FuelSave India."
    />
  </head>

  <body>
    <header class="navbar">
      <a class="logo" href="/">Praveen<span>Builds</span></a>

      <nav>
        <a href="/">Home</a>
        <a href="/#about">About</a>
        <a class="active" href="/blog">Blog</a>
        <a href="/#projects">Projects</a>
      </nav>
    </header>

    <main>
      <section class="blog-header">
        <p class="label">The blog</p>

        <h1>Learning by building.</h1>

        <p>
          Practical lessons from my projects in software, electronics,
          computer vision and automation.
        </p>
      </section>

      <section class="posts">
        {
          posts.map((post) => (
            <article class="post-card">
              <div class="post-meta">
                <span>{post.category}</span>
                <span>{post.date}</span>
                <span>{post.readingTime}</span>
              </div>

              <h2>
                <a href={post.href}>{post.title}</a>
              </h2>

              <p>{post.description}</p>

              <a class="read-link" href={post.href}>
                Read article →
              </a>
            </article>
          ))
        }
      </section>
    </main>

    <footer>
      <p>© {new Date().getFullYear()} Praveen Kumar</p>
      <p>Building products. Sharing the journey.</p>
    </footer>
  </body>
</html>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  :global(html) {
    scroll-behavior: smooth;
  }

  :global(body) {
    margin: 0;
    min-width: 320px;
    color: #e8edf6;
    background:
      radial-gradient(
        circle at 75% 5%,
        rgba(39, 136, 255, 0.14),
        transparent 27%
      ),
      #07111f;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
    line-height: 1.5;
  }

  :global(a) {
    color: inherit;
    text-decoration: none;
  }

  .navbar {
    width: min(1080px, calc(100% - 40px));
    min-height: 76px;
    margin: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    font-size: 1.15rem;
    font-weight: 800;
    letter-spacing: -0.03em;
  }

  .logo span,
  .active,
  .label,
  .read-link {
    color: #55a5ff;
  }

  nav {
    display: flex;
    gap: 28px;
  }

  nav a {
    color: #a9b5c8;
    font-size: 0.94rem;
  }

  nav a:hover {
    color: white;
  }

  main {
    width: min(1080px, calc(100% - 40px));
    min-height: calc(100vh - 155px);
    margin: auto;
  }

  .blog-header {
    max-width: 760px;
    padding: 110px 0 75px;
  }

  .label {
    margin-bottom: 16px;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0 0 24px;
    font-size: clamp(3rem, 7vw, 5.6rem);
    line-height: 0.98;
    letter-spacing: -0.06em;
  }

  .blog-header > p:last-child {
    max-width: 680px;
    color: #a9b5c8;
    font-size: 1.1rem;
    line-height: 1.8;
  }

  .posts {
    padding: 25px 0 110px;
    border-top: 1px solid #142238;
  }

  .post-card {
    padding: 38px 0;
    border-bottom: 1px solid #142238;
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    color: #74869e;
    font-size: 0.82rem;
  }

  .post-meta span:first-child {
    color: #55a5ff;
  }

  .post-card h2 {
    max-width: 760px;
    margin: 15px 0 12px;
    font-size: clamp(1.7rem, 4vw, 2.5rem);
    letter-spacing: -0.035em;
  }

  .post-card h2 a:hover {
    color: #55a5ff;
  }

  .post-card > p {
    max-width: 720px;
    color: #9eacc0;
    line-height: 1.75;
  }

  .read-link {
    display: inline-block;
    margin-top: 8px;
    font-weight: 700;
  }

  footer {
    width: min(1080px, calc(100% - 40px));
    margin: auto;
    padding: 30px 0;
    border-top: 1px solid #142238;
    color: #75849a;
    display: flex;
    justify-content: space-between;
    gap: 20px;
    font-size: 0.9rem;
  }

  @media (max-width: 650px) {
    nav {
      gap: 14px;
    }

    nav a:nth-child(2),
    nav a:nth-child(4) {
      display: none;
    }

    .blog-header {
      padding: 75px 0 55px;
    }

    footer {
      flex-direction: column;
    }
  }
</style>