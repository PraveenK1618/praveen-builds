---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = await getCollection("blog", ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true;
});

const sortedPosts = posts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

function formatDate(date: Date) {
  return new Intl.DateTimeFormat("en-IN", {
    day: "numeric",
    month: "long",
    year: "numeric",
  }).format(date);
}
---

<BaseLayout
  title="Blog | Praveen Builds"
  description="Articles by Praveen Kumar about Flutter, electronics, embedded systems, automation and building FuelSave India."
>
  <section class="blog-header container">
    <p class="section-label">The blog</p>

    <h1>Learning by building.</h1>

    <p>
      Practical lessons from my projects in software, electronics, computer
      vision and automation.
    </p>
  </section>

  <section class="posts container">
    {
      sortedPosts.length > 0 ? (
        sortedPosts.map((post) => (
          <article class="post-card">
            <div class="post-meta">
              <span>{post.data.category}</span>
              <span>{formatDate(post.data.pubDate)}</span>
              <span>{post.data.readingTime}</span>
            </div>

            <h2>
              <a href={`/blog/${post.id}`}>{post.data.title}</a>
            </h2>

            <p>{post.data.description}</p>

            <a class="read-link" href={`/blog/${post.id}`}>
              Read article →
            </a>
          </article>
        ))
      ) : (
        <p class="empty-state">No articles have been published yet.</p>
      )
    }
  </section>
</BaseLayout>

<style>
  .blog-header {
    max-width: 1080px;
    padding-block: 110px 75px;
  }

  .blog-header h1 {
    margin: 16px 0 24px;
    font-size: clamp(3rem, 7vw, 5.6rem);
    line-height: 0.98;
    letter-spacing: -0.06em;
  }

  .blog-header > p:last-child {
    max-width: 680px;
    color: var(--text-secondary);
    font-size: 1.1rem;
    line-height: 1.8;
  }

  .posts {
    padding-block: 25px 110px;
    border-top: 1px solid #142238;
  }

  .post-card {
    padding-block: 38px;
    border-bottom: 1px solid #142238;
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    color: var(--text-muted);
    font-size: 0.82rem;
  }

  .post-meta span:first-child,
  .read-link {
    color: var(--accent);
  }

  .post-card h2 {
    max-width: 760px;
    margin: 15px 0 12px;
    font-size: clamp(1.7rem, 4vw, 2.5rem);
    letter-spacing: -0.035em;
  }

  .post-card h2 a {
    transition: color 180ms ease;
  }

  .post-card h2 a:hover {
    color: var(--accent);
  }

  .post-card > p {
    max-width: 720px;
    color: var(--text-secondary);
    line-height: 1.75;
  }

  .read-link {
    display: inline-block;
    margin-top: 8px;
    font-weight: 700;
  }

  .empty-state {
    padding-block: 50px;
    color: var(--text-secondary);
  }

  @media (max-width: 650px) {
    .blog-header {
      padding-block: 75px 55px;
    }
  }
</style>