---
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = [
  {
    title: "Why I Built FuelSave India",
    description:
      "The problem that inspired me to build a fuel, mileage and vehicle expense tracking application.",
    date: "14 July 2026",
    category: "FuelSave India",
    readingTime: "5 min read",
    href: "/blog/why-i-built-fuelsave-india",
  },
];
---

<BaseLayout
  title="Blog | Praveen Builds"
  description="Articles by Praveen Kumar about Flutter, electronics, embedded systems, automation and building FuelSave India."
>
  <section class="blog-header container">
    <p class="section-label">The blog</p>

    <h1>Learning by building.</h1>

    <p>
      Practical lessons from my projects in software, electronics, computer
      vision and automation.
    </p>
  </section>

  <section class="posts container">
    {
      posts.map((post) => (
        <article class="post-card">
          <div class="post-meta">
            <span>{post.category}</span>
            <span>{post.date}</span>
            <span>{post.readingTime}</span>
          </div>

          <h2>
            <a href={post.href}>{post.title}</a>
          </h2>

          <p>{post.description}</p>

          <a class="read-link" href={post.href}>
            Read article →
          </a>
        </article>
      ))
    }
  </section>
</BaseLayout>

<style>
  .blog-header {
    max-width: 1080px;
    padding-block: 110px 75px;
  }

  .blog-header h1 {
    margin: 16px 0 24px;
    font-size: clamp(3rem, 7vw, 5.6rem);
    line-height: 0.98;
    letter-spacing: -0.06em;
  }

  .blog-header > p:last-child {
    max-width: 680px;
    color: var(--text-secondary);
    font-size: 1.1rem;
    line-height: 1.8;
  }

  .posts {
    padding-block: 25px 110px;
    border-top: 1px solid #142238;
  }

  .post-card {
    padding-block: 38px;
    border-bottom: 1px solid #142238;
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    color: var(--text-muted);
    font-size: 0.82rem;
  }

  .post-meta span:first-child,
  .read-link {
    color: var(--accent);
  }

  .post-card h2 {
    max-width: 760px;
    margin: 15px 0 12px;
    font-size: clamp(1.7rem, 4vw, 2.5rem);
    letter-spacing: -0.035em;
  }

  .post-card h2 a:hover {
    color: var(--accent);
  }

  .post-card > p {
    max-width: 720px;
    color: var(--text-secondary);
    line-height: 1.75;
  }

  .read-link {
    display: inline-block;
    margin-top: 8px;
    font-weight: 700;
  }

  @media (max-width: 650px) {
    .blog-header {
      padding-block: 75px 55px;
    }
  }
</style>